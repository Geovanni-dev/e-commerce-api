
// Configuração do banco
datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// Gerador do cliente (Padrão para JS)
generator client {
  provider = "prisma-client-js"
}

// Tabela de Usuários
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
}

// Tabela de Produtos
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Int
  createdAt   DateTime @default(now())
  // Relacionamento: Cada produto tem uma categoria
  category    Category ? @relation(fields: [categoryId], references: [id])
  categoryId  Int ?
}
// 
model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  // Relacionamento: Uma categoria tem muitos produtos
  products Product[]
}